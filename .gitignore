# Environment variables
.env
.env.*
*.env

# Virtual environments
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log

# SQLite database (optional, remove if you want to track it)
*.sqlite3

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Migrations cache (optional for Django, be careful)
**/migrations/*.pyc
**/migrations/__pycache__/

# Static/media (optional depending on setup)
media/
staticfiles/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/